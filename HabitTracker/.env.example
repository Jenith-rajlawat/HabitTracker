VITE_API_BASE_URL_EXAMPLE = http://localhost:8080/api/baseUrlExample 

# .env → root folder
# Vite → must use VITE_ prefix
# Access via → import.meta.env
# .env → read by Vite (build tool), not React
# Must be in root so Vite can find it
# import.meta.env → bridge from build → browser
# VITE_ → whitelist for safe exposure
# Values are injected at build time (not runtime)